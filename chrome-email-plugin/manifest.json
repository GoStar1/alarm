{
  "manifest_version": 3,
  "name": "Email Sender Plugin",
  "version": "1.0",
  "description": "点击按钮发送邮件",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://api.telegram.org/"
  ]
}
